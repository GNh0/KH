{
  "schema_version": 2,
  "contract_id": "pb-csharp-offline-generalized",
  "contract_version": "1.0",
  "normal_generation": {
    "profile_source": "packaged-only",
    "external_discovery_allowed": false,
    "source_text_policy": "passthrough",
    "profile_update_workflow": "profile-update-workflow.md",
    "profile_update_runs_during_normal_generation": false
  },
  "rules": {
    "csharp": {
      "required_patterns": [
        {
          "id": "mapped_form_declaration",
          "pattern": "\\bpartial\\s+class\\s+[A-Za-z_][A-Za-z0-9_]*Form\\s*:\\s*(?:Form|[A-Za-z_][A-Za-z0-9_.<>]*(?:Form|Base))\\b"
        },
        {
          "id": "designer_initialization",
          "pattern": "\\bInitializeComponent\\s*\\("
        },
        {
          "id": "migration_call_path",
          "pattern": "\\b(?:CallSelectProcedure|CallViewQuery|CallSaveProcedure|CallProc)\\s*\\("
        },
        {
          "id": "ui_binding_or_result_mapping",
          "pattern": "\\b(?:DataSource|BindingField|FieldName)\\s*="
        }
      ],
      "forbidden_patterns": [
        {
          "id": "alien_convention",
          "pattern": "\\bAlienConvention\\b"
        },
        {
          "id": "invented_request_context_dto",
          "pattern": "\\bclass\\s+[A-Za-z_][A-Za-z0-9_]*(?:Context|Request|Criteria)\\b"
        },
        {
          "id": "runtime_grid_column_factory",
          "pattern": "\\bAddGridColumn\\s*\\(|\\.Columns\\.AddField\\s*\\("
        },
        {
          "id": "inline_wildcard_shaping",
          "pattern": "(?:\\+\\s*\"%\"|\\?\\?\\s*\"%\")"
        }
      ],
      "evidence_requirements": [
        "all required structural pattern identifiers are reported",
        "the mapped form declaration and designer initialization are present",
        "one packaged migration call path is present",
        "one UI binding or result mapping is present",
        "empty source and unrelated class text are rejected"
      ]
    },
    "sql": {
      "allowed_procedure_patterns": [
        "^USP_[A-Z][A-Z0-9_]*_(?:SELECT|SAVE|SELECT_SAVE)$"
      ],
      "forbidden_patterns": [
        {
          "id": "temporary_table",
          "pattern": "#[A-Za-z][A-Za-z0-9_]*"
        },
        {
          "id": "merge",
          "pattern": "\\bMERGE\\b"
        },
        {
          "id": "not_exists",
          "pattern": "\\bNOT\\s+EXISTS\\b"
        }
      ]
    }
  },
  "designer_ownership": {
    "default_owner": ".Designer.cs",
    "designer_file_owns": [
      "control and component field declarations",
      "control and repository construction",
      "static parent containment and collection registration",
      "static Name TabIndex Location Size Dock and Anchor assignments",
      "static BindingField FieldName Caption Text and VisibleIndex assignments",
      "explicit grid columns and Columns.AddRange registration",
      "repository registration and ColumnEdit assignments",
      "static Appearance and Options assignments",
      "other static design-time properties"
    ],
    "code_behind_owns": [
      "runtime behavior and command logic",
      "event handler implementations",
      "procedure calls and validation",
      "runtime result and data binding",
      "evidence-backed dynamic state changes"
    ],
    "code_behind_static_ui_patterns": [
      {
        "id": "control_creation_outside_designer",
        "pattern": "\\bthis\\.[A-Za-z_][A-Za-z0-9_]*\\s*=\\s*new\\s+[A-Za-z_][A-Za-z0-9_.<>]*\\s*\\("
      },
      {
        "id": "static_property_outside_designer",
        "pattern": "\\bthis\\.[A-Za-z_][A-Za-z0-9_]*\\.(?:Name|TabIndex|Location|Size|Dock|Anchor|BindingField|FieldName|VisibleIndex|Caption|Text)\\s*="
      },
      {
        "id": "grid_or_repository_registration_outside_designer",
        "pattern": "\\bthis\\.[A-Za-z_][A-Za-z0-9_]*\\.(?:Columns|RepositoryItems)\\.AddRange\\s*\\("
      },
      {
        "id": "column_repository_assignment_outside_designer",
        "pattern": "\\bthis\\.[A-Za-z_][A-Za-z0-9_]*\\.ColumnEdit\\s*="
      },
      {
        "id": "appearance_or_options_outside_designer",
        "pattern": "\\bthis\\.[A-Za-z_][A-Za-z0-9_]*\\.(?:Appearance|Options)[A-Za-z0-9_.]*\\s*="
      }
    ],
    "dynamic_state_exception": {
      "default": "blocked",
      "requires": [
        "supplied source or explicit behavior evidence",
        "documented runtime reason",
        "targeted verification for the state transition"
      ]
    },
    "evidence_requirements": [
      "generated static UI assignments are inventoried by target file",
      "Designer-owned assignments appear only in the generated Designer file by default",
      "code-behind contains runtime behavior events data binding and approved dynamic state only",
      "every dynamic-state exception records evidence reason and verification",
      "misplaced static UI configuration blocks completion"
    ]
  },
  "style_families": {
    "screens": [
      "browse",
      "master-detail",
      "detail-entry",
      "popup"
    ],
    "methods": [
      "command",
      "event"
    ],
    "procedures": [
      "select",
      "save",
      "select-save"
    ]
  },
  "naming_grammar": {
    "form": "<Feature><Mode>Form",
    "load_handler": "<FormClass>_Load",
    "query_method": [
      "CallSelectProcedure",
      "CallViewQuery"
    ],
    "save_method": [
      "CallSaveProcedure",
      "CallProc"
    ],
    "focus_handler": "gvw<Role>_FocusedRowChanged",
    "controls": {
      "text": "txt<Field>",
      "button_lookup": "btn<Field>",
      "combo_lookup": "cbo<Field>",
      "numeric": "spn<Field>",
      "date": "dt<Field>",
      "boolean": "chk<Field>",
      "memo": "memo<Field>",
      "label": "lbl<Field>",
      "panel": "pnl<Role>",
      "group": "grp<Role>",
      "grid": "grd<Role>",
      "view": "gvw<Role>"
    },
    "grid_column": "col<Role>_<FIELD>",
    "repositories": {
      "button": "repButton<Field>",
      "lookup": "repLookup<Field>",
      "numeric": "repSpin<Field>",
      "boolean": "repCheck<Field>"
    },
    "procedure": "[dbo].[usp_<Feature>_<Operation>]",
    "procedure_parameter": "@<CALLER_VALUE>",
    "procedure_local": "@Local<DerivedValue>"
  },
  "event_method_shapes": {
    "command_handlers": [
      "SearchCommand",
      "SaveCommand",
      "ClearCommand",
      "DeleteCommand"
    ],
    "select": [
      "keep caller parameters adjacent to the call",
      "keep list and detail branches explicit",
      "return when a required focused row is absent",
      "bind each result table to one documented UI role"
    ],
    "save": [
      "validate before serialization",
      "serialize only documented row states",
      "call one save path",
      "refresh only after success"
    ]
  },
  "control_fallback_order": [
    "target-wrapper",
    "konelib",
    "devexpress",
    "winforms"
  ],
  "designer_properties": [
    "Name",
    "BindingField",
    "TabIndex",
    "Location",
    "Size",
    "Dock",
    "Anchor",
    "Text",
    "Caption",
    "EditValue",
    "Properties.*",
    "MainView",
    "ViewCollection",
    "GridControl",
    "Controls.Add",
    "Columns.AddRange"
  ],
  "tab_index_contract": {
    "scope": "each independent container",
    "controls": "located input controls only",
    "order": "row-major top-to-bottom/left-to-right",
    "values_required": true,
    "values_unique": true,
    "values_contiguous_increasing": true,
    "containers_validated_independently": true,
    "container_sequences_may_restart": true
  },
  "grid_repository_conventions": {
    "explicit_grid_columns": true,
    "explicit_grid_control_view_wiring": true,
    "register_with_columns_addrange": true,
    "field_name_matches_result": true,
    "register_repository_before_column_edit": true,
    "numeric_uses_repository_editor": true,
    "numeric_grid_display_format_forbidden": true,
    "xml_column_edit_name_only": true,
    "layout_load_artifact_and_designer_required": true,
    "caller_authored_load_evidence_accepted": false,
    "lookup_uses_supplied_value_display_members": true,
    "button_uses_explicit_event": true,
    "boolean_uses_check_repository_when_supported": true
  },
  "grid_layout_load_contract": {
    "workflow": "DataWindow -> generated View XML -> DevExpress GridControl Designer Layout -> Load -> target Designer state",
    "authority": "The generated XML values are the authoritative baseline for the resulting GridView and GridColumn Designer state.",
    "serializer": {"version": "1.0", "application": "View"},
    "xml_view_defaults": {
      "BestFitMaxRowCount": "-1",
      "PreviewLineCount": "-1",
      "HorzScrollStep": "3",
      "FocusRectStyle": "CellFocus",
      "ScrollStyle": "LiveVertScroll, LiveHorzScroll",
      "PreviewIndent": "-1",
      "GroupPanelText": "",
      "PreviewFieldName": "",
      "VertScrollTipFieldName": "",
      "NewItemRowText": "",
      "ViewCaption": "",
      "LevelIndent": "-1",
      "GroupFooterShowMode": "VisibleIfExpanded",
      "SynchronizeClones": "true",
      "BorderStyle": "Default",
      "DetailHeight": "350",
      "DetailTabHeaderLocation": "Top",
      "ActiveFilterEnabled": "true"
    },
    "xml_options_view_defaults": {
      "ShowViewCaption": "false",
      "EnableAppearanceEvenRow": "true",
      "ShowGroupPanel": "false",
      "ColumnAutoWidth": "false",
      "ShowFooter": "true",
      "ShowAutoFilterRow": "true"
    },
    "xml_column_defaults": {
      "AppearanceHeader.Options.UseTextOptions": "true",
      "AppearanceHeader.Options.UseFont": "true",
      "AppearanceHeader.TextOptions.HAlignment": "Center",
      "AppearanceHeader.TextOptions.VAlignment": "Center",
      "AppearanceHeader.Font": "Tahoma, 9pt",
      "AppearanceCell.Options.UseFont": "true",
      "AppearanceCell.Font": "Tahoma, 9pt",
      "Visible": "true",
      "FieldName": "uppercase source field exactly, including # and $",
      "Name": "configured prefix plus uppercase source field exactly, including # and $",
      "VisibleIndex": "one-based PB column=( occurrence order",
      "Caption": "uppercase FieldName exactly as emitted by DataWindowToXml; mapped PB captions are intentional post-conversion C# Designer overrides",
      "ColumnEditName": ""
    },
    "csharp_designer_result": {
      "default_application": "Equivalent authoritative values are explicit in Designer.cs.",
      "artifact_and_designer_requirement": "An explicit grid contract requires valid Layout-Load-ready XML and matching post-load-equivalent C# Designer source; neither passes alone.",
      "caller_authored_load_evidence_accepted": false,
      "actual_live_layout_load_observed": false,
      "verification_scope": "static_xml_and_post_load_equivalent_designer_state",
      "xml_column_name_is_separate_from_csharp_name": true,
      "xml_view_name_is_not_csharp_name": true,
      "list_names": ["grdList", "gvwList", "colList_<FIELD>"],
      "detail_names": ["grdDetail", "gvwDetail", "colDetail_<FIELD>"],
      "table_or_purpose_names": ["grd<SUFFIX>", "gvw<SUFFIX>", "col<SUFFIX>_<FIELD>"],
      "default_col_list_only_for_list_role": true,
      "requires_main_view_view_collection_grid_control_wiring": true,
      "requires_columns_addrange": true,
      "visible_index_base": 1,
      "requires_exact_visible_index_order": true,
      "requires_repository_registration_before_column_edit": true,
      "numeric_repository_type": "RepositoryItemSpinEdit",
      "numeric_grid_display_format_forbidden": true,
      "column_edit_name_emitted_in_csharp": false
    }
  },
  "caller_parameter_rules": [
    "every procedure parameter has a caller source or documented external caller",
    "caller and procedure parameter order stay synchronized",
    "internal and derived values are local procedure variables",
    "raw search and date values cross the caller boundary",
    "result fields match C# bindings and grid FieldName values"
  ],
  "stored_procedure_rules": {
    "metadata_fields": [
      "AUTHOR",
      "CREATE DATE",
      "DESCRIPTION"
    ],
    "set_nocount": true,
    "parameter_layout": "leading-comma",
    "select_column_layout": "leading-comma",
    "outer_alias_grammar": [
      "A",
      "A1",
      "B",
      "C"
    ],
    "derived_alias_grammar": [
      "T",
      "T1",
      "TA1"
    ],
    "complete_body_requires": [
      "supplied source SQL",
      "supplied current procedure",
      "supplied schema or result/write contract",
      "explicit inferred-draft approval"
    ]
  },
  "forbidden_patterns": [
    "private packaged identifiers or fingerprints",
    "normal-generation discovery or profile refresh",
    "invented request or context DTOs",
    "parallel query or save helpers",
    "inline C# wildcard shaping",
    "hidden query-path date defaults",
    "derived procedure helper parameters",
    "procedure parameters outside the caller matrix",
    "runtime grid-column factories",
    "fixed-column runtime loops",
    "numeric DisplayFormat-only behavior",
    "source-unbacked result schemas",
    "unapproved dependency upgrades or semantic SQL rewrites"
  ],
  "evidence_requirements": [
    "contract id and version",
    "selected style families and fallback reasons",
    "user directive and approved scope",
    "confirmed inferred blocked and proposal-only ledger",
    "event-to-method mapping",
    "field control grid and result mapping",
    "caller-parameter and local-variable matrices",
    "Designer and repository plan",
    "Designer ownership inventory and code-behind static UI scan",
    "procedure result write transaction and error contract",
    "forbidden-pattern scan",
    "verification results and residual blockers",
    "required C# structural pattern match or missing-pattern evidence",
    "token_optimizer_status passthrough"
  ]
}
