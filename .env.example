# =============================================================================
# Antigravity Universal Agent Framework - 환경변수 설정 예시
# =============================================================================
# 사용 방법:
#   1. 이 파일을 복사하여 `.env` 로 저장하세요.
#   2. 필요한 값을 수정하세요.
#   3. CLI 실행 전 `set` (Windows) 또는 `export` (Linux/Mac) 로 로드하거나,
#      python-dotenv 등을 사용하세요.
#
# AI 에이전트 참고: 기본값 그대로 실행해도 로컬에서 완벽하게 동작합니다.
# =============================================================================

# -----------------------------------------------------------------------------
# 네트워크 설정
# -----------------------------------------------------------------------------

# 웹훅 서버 주소 (cli.py --port 옵션과 일치해야 함)
# 기본값: http://127.0.0.1:8000/api/webhook/subagent-result
AG_WEBHOOK_URL=http://127.0.0.1:8000/api/webhook/subagent-result

# -----------------------------------------------------------------------------
# 보안 설정
# -----------------------------------------------------------------------------

# Webhook API 인증 키 (server.py와 workflows.py 양쪽에 자동 동기화됨)
# 운영 환경에서는 반드시 안전한 랜덤 문자열로 교체하세요!
# 기본값: antigravity-secret-key-v2
AG_API_KEY=antigravity-secret-key-v2

# -----------------------------------------------------------------------------
# 성능 설정
# -----------------------------------------------------------------------------

# 최대 동시 워커 수
# 실제 적용값은 min(이 값, CPU코어 * 10) 으로 자동 캡이 씌워짐
# 기본값: 50
AG_MAX_WORKERS=50

# -----------------------------------------------------------------------------
# 디버그 / 개발 설정
# -----------------------------------------------------------------------------

# 보안 샌드박스 비활성화 (1=OFF, 0=ON)
# ⚠️  운영 환경에서는 반드시 0으로 유지하세요!
# 기본값: 0
AG_NO_SANDBOX=0

# 서버 상세 로그 출력 (1=ON, 0=OFF)
# 기본값: 0
AG_VERBOSE=0
